# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # development | production

# ── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/plantube

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=AIzaSy...

# ── AI Service (aichixia.xyz) ─────────────────────────────────────────────────
# https://aichixia.xyz — key format: acv-...
AICHIXIA_API_KEY=acv-...

# ── CORS ─────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash)
CLIENT_URL=https://plantube.vercel.app
